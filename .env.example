# Copy this file to .env and fill in your values.
# Never commit .env to git.

# --- LLM Provider API Keys ---
# At least one is required to run the examples.
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# --- ARIA Configuration ---
# Path to the SQLite audit ledger. Defaults to ~/.aria/ledger.db
# ARIA_LEDGER_PATH=/path/to/your/ledger.db

# HMAC secret for trust token signing.
# Auto-generated if not set (resets between process restarts).
# ARIA_SESSION_SECRET=your-secret-here

# --- Logging ---
# Set to DEBUG for verbose output from all ARIA layers.
# ARIA_LOG_LEVEL=INFO
